# Get from @BotFather: /newbot, then copy the token here
BOT_TOKEN=

# Your Telegram numeric user ID. Only this ID can talk to the bot.
# Easiest way: set OWNER_ID=0, run the bot, send it any message — it will
# reply with your ID. Then put it here and restart.
OWNER_ID=0

# Where SQLite database file lives (relative to repo root or absolute)
DB_PATH=tgmusic.db

# Mini App backend HTTP server. 127.0.0.1 = only reachable through a tunnel
# (cloudflared). Set to 0.0.0.0 only if you front it with Caddy/Nginx on
# the same box and don't want to use a tunnel.
WEB_HOST=127.0.0.1
WEB_PORT=8080

# Origin allowed to call /api/* — exact URL of your Mini App on Cloudflare
# Pages (no trailing slash), e.g. https://tg-music.pages.dev. Use "*" only
# while developing.
CORS_ORIGIN=*
